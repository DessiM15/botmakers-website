# .env.example — Botmakers CRM v1
# Copy to .env.local and fill in all values.
# App will refuse to start if required vars are missing.

# ============================================
# APP (required)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Botmakers CRM
NODE_ENV=development

# ============================================
# SUPABASE (required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ============================================
# EMAIL — Resend (required)
# ============================================
RESEND_API_KEY=re_...
EMAIL_FROM=info@botmakers.ai
EMAIL_LEADS_FROM=leads@botmakers.ai

# ============================================
# AI — Anthropic (required)
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# PAYMENTS — Square (required for billing features)
# ============================================
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=L...
SQUARE_ENVIRONMENT=sandbox
# Set to 'production' when going live
SQUARE_WEBHOOK_SIGNATURE_KEY=...
# From Square Dashboard > Webhooks > Signature Key

# ============================================
# VCS — GitHub (required for repo integration)
# ============================================
GITHUB_TOKEN=ghp_...
# Personal access token with repo read permissions
GITHUB_WEBHOOK_SECRET=...
# Set when configuring GitHub webhooks

# ============================================
# VERCEL (required for deployment webhook)
# ============================================
VERCEL_WEBHOOK_SECRET=...
# From Vercel Dashboard > Settings > Webhooks

# ============================================
# RATE LIMITING — Upstash Redis (required)
# ============================================
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ============================================
# CRON (required for scheduled jobs)
# ============================================
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ============================================
# OPTIONAL: SMS — Twilio
# ============================================
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...
# Leave commented out — app gracefully skips SMS if not configured

# ============================================
# TEAM EMAILS (for notifications)
# ============================================
TEAM_NOTIFICATION_EMAILS=jay@m.botmakers.ai,tdaniel@botmakers.ai,dessiah@m.botmakers.ai
